generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  events       Event[]
}

model Event {
  id                String       @id @default(cuid())
  userId            String
  title             String
  slug              String       @unique
  eventDate         DateTime?
  startTime         String?
  venue             String?
  description       String?
  profileImageUrl   String?
  coverImageUrl     String?
  invitationFileUrl String?
  status            EventStatus  @default(DRAFT)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  eventDrinks       EventDrink[]
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  guests            Guest[]
  tables            Table[]
}

model Table {
  id       String  @id @default(cuid())
  eventId  String
  name     String
  capacity Int
  guests   Guest[]
  event    Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, name])
}

model Guest {
  id                String         @id @default(cuid())
  eventId           String
  tableId           String?
  token             String         @unique @default(cuid())
  firstName         String
  lastName          String
  email             String?
  phone             String?
  invitationType    InvitationType @default(SINGLE)
  plusOneFirstName  String?
  plusOneLastName   String?
  rsvpStatus        RsvpStatus     @default(PENDING)
  checkedInAt       DateTime?
  rsvpMessage       String?
  respondedAt       DateTime?
  plusOneRsvpStatus RsvpStatus?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  event             Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  table             Table?         @relation(fields: [tableId], references: [id])
  drinks            GuestDrink[]

  @@index([eventId])
  @@index([token])
  @@index([tableId])
}

model GuestDrink {
  id         String        @id @default(cuid())
  guestId    String
  drinkId    String
  assignedTo DrinkAssignee @default(PRIMARY)
  quantity   Int           @default(1)
  drink      Drink         @relation(fields: [drinkId], references: [id], onDelete: Cascade)
  guest      Guest         @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@unique([guestId, drinkId, assignedTo])
}

model EventDrink {
  id        String   @id @default(cuid())
  eventId   String
  drinkId   String
  createdAt DateTime @default(now())
  drink     Drink    @relation(fields: [drinkId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, drinkId])
  @@index([eventId])
  @@index([drinkId])
}

model Drink {
  id          String       @id @default(cuid())
  name        String
  category    String?
  isAlcoholic Boolean      @default(true)
  imageUrl    String?
  guestDrinks GuestDrink[]
  eventDrinks EventDrink[]

  @@unique([name, isAlcoholic])
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum InvitationType {
  SINGLE
  COUPLE
  DUO
}

enum RsvpStatus {
  PENDING
  CONFIRMED
  DECLINED
}

enum DrinkAssignee {
  PRIMARY
  PLUS_ONE
}
